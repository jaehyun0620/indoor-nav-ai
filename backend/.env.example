# ⚠️  이 파일은 예시입니다. 실제 키를 여기에 입력하지 마세요.
# .env 파일을 따로 만들어서 사용하세요. (.env 는 gitignore 처리됨)

# VLM 선택: openai 또는 gemini
VLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash

# 실험 조건: baseline / structured / proposed
EXPERIMENT_CONDITION=proposed

# YOLO / MiDaS 설정
YOLO_MODEL=yolov8n.pt
YOLO_CONF=0.4
MIDAS_MODEL=MiDaS_small
MIDAS_SCALE=5.0

# 느린 채널 주기 (초)
SLOW_CHANNEL_INTERVAL=2.5
